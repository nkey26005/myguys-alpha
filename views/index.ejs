<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MyGuys — Messenger Alpha 1.0</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.socket.io/4.8.0/socket.io.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');
    body { font-family: 'Inter', system-ui, sans-serif; }
    .chat-container { height: calc(100vh - 4rem); }
  </style>
</head>
<body class="bg-zinc-950 text-zinc-100">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <div class="w-80 bg-zinc-900 border-r border-zinc-800 flex flex-col">
      <div class="p-5 border-b border-zinc-800 flex items-center gap-3">
        <div class="w-9 h-9 bg-violet-600 rounded-2xl flex items-center justify-center text-xl">👥</div>
        <div>
          <h1 class="text-2xl font-semibold tracking-tight">MyGuys</h1>
          <p class="text-xs text-emerald-400">Alpha 1.0</p>
        </div>
      </div>
      
      <div class="p-4">
        <div class="bg-zinc-800 rounded-3xl p-4 text-sm">
          <div class="flex items-center gap-2 text-emerald-400 mb-3">
            <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
            <span id="online-count">0 онлайн</span>
          </div>
          <p class="text-zinc-400 text-xs">Общий чат • Все пользователи</p>
        </div>
      </div>
    </div>

    <!-- Main Chat -->
    <div class="flex-1 flex flex-col">
      <div class="h-14 bg-zinc-900 border-b border-zinc-800 px-6 flex items-center">
        <div class="flex items-center gap-3">
          <div class="text-2xl">🌍</div>
          <div>
            <h2 class="font-semibold">Общий чат</h2>
            <p class="text-xs text-zinc-500">Реальное время • Alpha версия</p>
          </div>
        </div>
      </div>

      <div id="messages" class="flex-1 p-6 overflow-y-auto space-y-6 bg-zinc-950 chat-container">
        <!-- JS will add messages here -->
      </div>

      <div class="p-5 bg-zinc-900 border-t border-zinc-800">
        <div class="flex gap-3">
          <input id="username" 
                 type="text" 
                 placeholder="Твоё имя"
                 class="bg-zinc-800 border border-zinc-700 focus:border-violet-500 rounded-3xl px-6 py-4 text-sm flex-1 outline-none transition-all">
          <input id="message-input" 
                 type="text" 
                 placeholder="Напиши сообщение..."
                 class="bg-zinc-800 border border-zinc-700 focus:border-violet-500 rounded-3xl px-6 py-4 text-sm flex-[2] outline-none transition-all">
          <button onclick="sendMessage()"
                  class="bg-violet-600 hover:bg-violet-700 px-8 rounded-3xl font-medium transition-colors">
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
        <p class="text-center text-[10px] text-zinc-500 mt-3">MyGuys Alpha 1.0 • Работает на Socket.io</p>
      </div>
    </div>
  </div>

  <script>
    const socket = io();
    let myUsername = '';

    function formatTime(date) {
      return new Date(date).toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
    }

    function addMessage(msg, isOwn = false) {
      const container = document.getElementById('messages');
      const div = document.createElement('div');
      div.className = `flex ${isOwn ? 'justify-end' : 'justify-start'} group`;
      
      div.innerHTML = `
        <div class="max-w-[70%] ${isOwn ? 'bg-violet-600 text-white' : 'bg-zinc-800 text-zinc-100'} rounded-3xl px-5 py-3.5">
          ${!isOwn ? `<p class="text-violet-400 text-xs mb-1 font-medium">${msg.username}</p>` : ''}
          <p class="text-[15px] leading-relaxed">${msg.text}</p>
          <p class="text-[10px] mt-2 opacity-60 text-right">${formatTime(msg.timestamp)}</p>
        </div>
      `;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }

    function sendMessage() {
      const input = document.getElementById('message-input');
      const usernameInput = document.getElementById('username');
      
      const text = input.value.trim();
      if (!text) return;

      if (!myUsername) {
        myUsername = usernameInput.value.trim() || `Гость${Math.floor(Math.random() * 999)}`;
        usernameInput.value = myUsername;
        usernameInput.disabled = true;
        socket.emit('join', myUsername);
      }

      socket.emit('send_message', { text });
      input.value = '';
    }

    // Socket listeners
    socket.on('connect', () => {
      console.log('%c✅ Подключено к MyGuys Alpha 1.0', 'color: violet; font-weight: bold');
    });

    socket.on('previous_messages', (msgs) => {
      msgs.forEach(msg => {
        const isOwn = msg.username === myUsername;
        addMessage(msg, isOwn);
      });
    });

    socket.on('new_message', (msg) => {
      const isOwn = msg.username === myUsername;
      addMessage(msg, isOwn);
    });

    // Keyboard support
    document.getElementById('message-input').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') sendMessage();
    });
  </script>
</body>
</html>