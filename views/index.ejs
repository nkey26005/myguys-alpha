<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Guys Messenger v0.1 - <%= room %></title>
  <style>
    body { font-family: Arial, sans-serif; background: #f0f2f5; margin: 0; padding: 0; }
    .container { max-width: 980px; margin: 20px auto; background: white; border-radius: 10px; box-shadow: 0 0 15px rgba(0,0,0,0.1); overflow: hidden; display: flex; }
    .sidebar { width: 250px; background: #1f2937; color: white; padding: 20px; }
    .sidebar h2 { margin-top: 0; }
    .users { list-style: none; padding: 0; }
    .users li { padding: 8px; background: rgba(255,255,255,0.1); margin: 5px 0; border-radius: 5px; }
    .chat-area { flex: 1; display: flex; flex-direction: column; }
    header { background: #2563eb; color: white; padding: 20px; text-align: center; }
    #messages { flex: 1; overflow-y: auto; padding: 20px; background: #f9fafb; }
    .message { margin: 10px 0; padding: 10px 15px; background: #e5e7eb; border-radius: 15px; max-width: 75%; }
    .my-message { background: #2563eb; color: white; margin-left: auto; border-bottom-right-radius: 5px; }
    .meta { display: block; margin-top: 6px; font-size: 12px; opacity: 0.8; }
    .system-message { margin: 8px 0; color: #4b5563; font-style: italic; }
    #input-area { padding: 20px; display: flex; flex-direction: column; background: #f3f4f6; }
    input { padding: 12px; margin-bottom: 10px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 16px; }
    button { padding: 12px; background: #2563eb; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; }
    button:disabled { background: #9ca3af; cursor: not-allowed; }
    #typing { padding: 10px; color: #666; font-style: italic; min-height: 20px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <h2>Room: <%= room %></h2>
      <p>Online users:</p>
      <ul id="users-list" class="users"></ul>
      <p style="font-size:12px; margin-top:30px;">My Guys Messenger v0.1 🚀</p>
    </div>

    <div class="chat-area">
      <header>
        <h1>My Guys Messenger</h1>
        <p>Simple real-time chat (version 0.1)</p>
      </header>
      <div id="messages"></div>
      <div id="typing"></div>
      <div id="input-area">
        <input type="text" id="nickname" placeholder="Your nickname (press Enter)" autocomplete="off"/>
        <input type="text" id="message" placeholder="Type a message..." autocomplete="off" disabled/>
        <button id="send" disabled>Send</button>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const room = "<%= room %>";

    const messages = document.getElementById('messages');
    const usersList = document.getElementById('users-list');
    const nicknameInput = document.getElementById('nickname');
    const messageInput = document.getElementById('message');
    const sendButton = document.getElementById('send');
    const typingDiv = document.getElementById('typing');

    let nickname = '';

    nicknameInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && nicknameInput.value.trim()) {
        nickname = nicknameInput.value.trim();
        socket.emit('joinRoom', { room, nick: nickname });
        nicknameInput.disabled = true;
        messageInput.disabled = false;
        sendButton.disabled = false;
        messageInput.focus();
      }
    });

    function formatTime(iso) {
      if (!iso) return '';
      return new Date(iso).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function sendMessage() {
      const msg = messageInput.value.trim();
      if (!msg) return;
      socket.emit('chatMessage', msg);
      messageInput.value = '';
      socket.emit('typing', false);
    }

    sendButton.addEventListener('click', sendMessage);
    messageInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') sendMessage();
    });

    messageInput.addEventListener('input', () => {
      socket.emit('typing', messageInput.value.length > 0);
    });

    function addMessage(data) {
      const isMy = data.nickname === nickname;
      const div = document.createElement('div');
      div.classList.add('message');
      if (isMy) div.classList.add('my-message');
      div.innerHTML = `<strong>${data.nickname}:</strong> ${data.message}<span class="meta">${formatTime(data.timestamp)}</span>`;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function addSystemMessage(text) {
      const div = document.createElement('div');
      div.classList.add('system-message');
      div.textContent = text;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function updateUsers(users) {
      usersList.innerHTML = '';
      users.forEach((user) => {
        const li = document.createElement('li');
        li.textContent = user;
        usersList.appendChild(li);
      });
    }

    socket.on('chatHistory', (history) => {
      messages.innerHTML = '';
      history.forEach((item) => addMessage(item));
    });

    socket.on('chatMessage', (data) => addMessage(data));
    socket.on('systemMessage', (text) => addSystemMessage(text));
    socket.on('updateUsers', (users) => updateUsers(users));
    socket.on('typing', (data) => {
      typingDiv.textContent = data.isTyping ? `${data.nickname} is typing...` : '';
    });
  </script>
</body>
</html>
